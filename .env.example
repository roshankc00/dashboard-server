NODE_ENV=development
PORT=3000
LOG_LEVEL=info

MONGODB_URI=mongodb://root:devpassword@127.0.0.1:27017/dashboard?authSource=admin
REDIS_URL=redis://127.0.0.1:6379

# BullMQ key prefix (use distinct values per env)
BULLMQ_PREFIX=urlcheck

# Batch list cache TTL (seconds)
BATCH_LIST_CACHE_TTL_SEC=30

# Per-URL HTTP timeout (ms)
URL_FETCH_TIMEOUT_MS=20000

# Max URLs accepted in one POST /api/batches
MAX_URLS_PER_BATCH=500

# Comma-separated allowed origins in production, e.g.:
# CORS_ORIGIN=https://dashboard.example.com

# Optional compose port overrides
# MONGO_PORT=27017
# REDIS_PORT=6379
